              <a
                href="https://twitter.com/yashab_yadav"
                target="_blank"
                rel="noopener noreferrer">Twitter</a
              >, or check out my
              <a
                href="https://github.com/yashabyadav"
                target="_blank"
                rel="noopener noreferrer">GitHub</a
              >.
            </p>
          </section>

          <div class="ornament-divider dinkus">
            <span class="glyph">❧</span>
          </div>
        </div>
      </nav>
    </div>

    <script>
      // ==========================================================
      // Codex home — ported from the Paper & ASCII Design System:
      //   AsciiBanner (Gray-Scott "turing" mode) + AsciiText typewriter.
      //   Framework-free so it runs in this Astro page. Cleans up on
      //   Astro view-transition navigation.
      // ==========================================================
      const RAMP = " .:-=+*#%@";

      function startBanner(el: HTMLElement, { cols = 46, rows = 26, fps = 24, feed = 0.055, kill = 0.062 } = {}) {
        // Gray-Scott reaction-diffusion (a Turing pattern-forming system):
        //   da/dt = Da*lap(a) - a*b^2 + feed*(1-a)
        //   db/dt = Db*lap(b) + a*b^2 - (kill+feed)*b
        // STEPS integration steps are advanced per rendered frame; a lower
        // STEPS makes the time evolution slower and easier to watch grow.
        const N = cols * rows;
        const Da = 1.0, Db = 0.5, dt = 1.0, STEPS = 3, RESEED = 900;
        let a = new Float32Array(N), b = new Float32Array(N);
        let na = new Float32Array(N), nb = new Float32Array(N);
        let iters = 0;

        const wrap = (x: number, y: number) =>
          (((y % rows) + rows) % rows) * cols + (((x % cols) + cols) % cols);

        function seedShapes() {
          a.fill(1); b.fill(0);
          const n = 3 + Math.floor(Math.random() * 4);
          for (let s = 0; s < n; s++) {
            const type = Math.floor(Math.random() * 4);
            const cx = Math.floor(Math.random() * cols);
            const cy = Math.floor(Math.random() * rows);
            const w = 2 + Math.floor(Math.random() * 5);
            const h = 2 + Math.floor(Math.random() * 5);
            const sq = 2 + Math.floor(Math.random() * 4);
            for (let dy = -h - 1; dy <= h + 1; dy++) {
              for (let dx = -w - 1; dx <= w + 1; dx++) {
                let inside = false;
                if (type === 0) inside = Math.abs(dx) <= sq && Math.abs(dy) <= sq;
                else if (type === 1) inside = Math.abs(dx) <= w && Math.abs(dy) <= Math.max(1, h >> 1);
                else if (type === 2) inside = (dx * dx) / (w * w + 0.01) + (dy * dy) / (h * h + 0.01) <= 1;
                else {
                  const ty = dy + h;
                  inside = ty >= 0 && ty <= 2 * h && Math.abs(dx) <= w * (1 - ty / (2 * h + 0.01));
                }
                if (inside) b[wrap(cx + dx, cy + dy)] = 1.0;
              }
            }
          }
          for (let i = 0; i < N; i++) a[i] += (Math.random() - 0.5) * 0.01;
        }

        function step() {
          for (let y = 0; y < rows; y++) {
            for (let x = 0; x < cols; x++) {
              const i = y * cols + x;
              const l = wrap(x - 1, y), r = wrap(x + 1, y), u = wrap(x, y - 1), d = wrap(x, y + 1);
              const ul = wrap(x - 1, y - 1), ur = wrap(x + 1, y - 1), dl = wrap(x - 1, y + 1), dr = wrap(x + 1, y + 1);
              const lapA = -a[i] + 0.2 * (a[l] + a[r] + a[u] + a[d]) + 0.05 * (a[ul] + a[ur] + a[dl] + a[dr]);
              const lapB = -b[i] + 0.2 * (b[l] + b[r] + b[u] + b[d]) + 0.05 * (b[ul] + b[ur] + b[dl] + b[dr]);
              const abb = a[i] * b[i] * b[i];
              const va = a[i] + (Da * lapA - abb + feed * (1 - a[i])) * dt;
              const vb = b[i] + (Db * lapB + abb - (kill + feed) * b[i]) * dt;
              na[i] = va < 0 ? 0 : va > 1 ? 1 : va;
              nb[i] = vb < 0 ? 0 : vb > 1 ? 1 : vb;
            }
          }
          a.set(na); b.set(nb);
        }

        function render() {
          const lines = [];
          for (let y = 0; y < rows; y++) {
            let line = "";
            for (let x = 0; x < cols; x++) {
              const v = b[y * cols + x];
              let n = (v - 0.14) * 6.5;
              n = n > 0.999 ? 0.999 : n < 0 ? 0 : n;
              line += RAMP[Math.floor(n * RAMP.length)];
            }
            lines.push(line);
          }
          el.textContent = lines.join("\n");
        }

        seedShapes();

        // The Turing figure always animates its propagation from the seeds —
        // that time evolution is the whole point of the plate, so it runs even
        // under prefers-reduced-motion (the static ambient modes would not).
        let raf: number, last = 0;
        const interval = 1000 / fps;
        function frame(now: number) {
          raf = requestAnimationFrame(frame);
          if (now - last < interval) return;
          last = now;
          for (let s = 0; s < STEPS; s++) step();
          iters += STEPS;
          if (iters > RESEED) { seedShapes(); iters = 0; }
          render();
        }
        raf = requestAnimationFrame(frame);
        return () => cancelAnimationFrame(raf);
      }

      function startTypewriter(el: HTMLElement, { speed = 45, startDelay = 250 } = {}) {
        const text = el.dataset.text || el.textContent || "";
        const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        if (reduce) {
          el.textContent = text;
          el.classList.remove("ascii-caret");
          return () => {};
        }
        let ci = 0, timer: ReturnType<typeof setTimeout>;
        el.textContent = "";
        const tick = () => {
          if (ci <= text.length) {
            el.textContent = text.slice(0, ci);
            ci += 1;
            timer = setTimeout(tick, speed);
          } else {
            el.classList.remove("ascii-caret");
          }
        };
        timer = setTimeout(tick, startDelay);
        return () => clearTimeout(timer);
      }

      let cleanups: Array<() => void> = [];
      function initCodexHome() {
        cleanups.forEach((fn) => fn && fn());
        cleanups = [];
        const banner = document.getElementById("ascii-banner");
        const hero = document.getElementById("hero-name");
        if (banner) cleanups.push(startBanner(banner));
        if (hero) cleanups.push(startTypewriter(hero));
      }

      document.addEventListener("astro:page-load", initCodexHome);
      document.addEventListener("astro:before-swap", () => {
        cleanups.forEach((fn) => fn && fn());
        cleanups = [];
      });
    </script>
  </body>
</html>
