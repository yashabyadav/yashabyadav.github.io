<!doctype html>
<html>
  <Header title="Yashab Yadav" />
  <body>
    <div class="content">
      <Sidebar selectedItem="home" />
      <nav class="main">
        <div class="container">
          <main class="fold-content-container">
            <div class="fold-content">
              <h1 class="heading-red">Hi! I'm Yashab</h1>
              <p class="lead">
                I work on understanding the mechanobiology of the cell using
                mathematical and computational modelling.
              </p>
              <p class="lead">
                Welcome to my online space which serves as my portfolio, notes
                collection, project showcases and other random stuff.
              </p>
            </div>

            <!-- section class="news-section">
              <div class="section-title">
                <h3 class="heading-red">News</h3>
              </div>
              <div class="section-content">
                <article>
                  <aside>
                    <div class="dot"></div>
                  </aside>
                  <div>
                    <time class="news-date" datetime="2026-02">Feb 2026</time>
                    <div class="news-title">
                      Attended the Biophysical Society Annual Meeting in San
                      Francisco and presented a poster on ongoing research.
                    </div>
                  </div>
                </article>
              </div>
