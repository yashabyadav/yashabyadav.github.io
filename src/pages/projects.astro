---
import Header from "../components/Header.astro";
import Sidebar from "../components/Sidebar.astro";

import { Image } from 'astro:assets';
import tractionForceImage from '../content/projects/traction-force-prediction-ml-project.png';

type ProjectCard = {
  id: string;
  title: string;
  subtitle?: string;
  shortDescription: string;
  fullDescription: string;
  tags: string[];
};

const personalProjects: ProjectCard[] = [
  {
    id: "homelab",
    title: "Homelab",
    shortDescription: "Self-hosted infrastructure for learning and experimentation",
    fullDescription: `As much as I like watching PewDiePie, I think I come off as a try hard when I tell people about my homelab and then try to convince them that I got into the hobby before <a href="https://www.youtube.com/@PewDiePie">he made it cool</a>.<br/><br/>In any case, working on a homelab is such a rewarding hobby in my experience. To read more about what I have been working on checkout my <a href="/projects/homelab">homelab page</a>.`,
    tags: ["Linux", "Networking", "Open source software", "Docker", "Hardware"]
  },
  {
    id: "photo-frame",
    title: "Raspberry Pi Digital Photo Frame",
    shortDescription: "Custom 3D-printed digital photo frame with remote access",
    fullDescription: `Made this during the summer as a gift for my partner. I could've gotten a pre-built display but where's the fun in that? Plus, I like the idea of making something by hand as it makes the gift more meaningful.<br/><br/>I got a display tiny 7.5 inch display, a Raspberry Pi, and 3D printed a frame (had to learn a little bit of 3D modelling for this which was fun). I wrote a simple Python script that pulls photos from a flash drive and displays them in a slideshow format. I also connected it to my tailnet so that I can access it remotely in case I need to troubleshoot.`,
    tags: ["Linux", "Python", "Open source software", "Hardware"]
  }
];

const courseProjects: ProjectCard[] = [
  {
    id: "traction-force",
    title: "Traction Force Prediction from Fluorescent Cell Images",
    subtitle: "Machine Learning (Fall 2024)",
    shortDescription: "U-Net model for predicting cellular traction forces from fluorescence microscopy",
    fullDescription: `I chose this project for my machine learning course project to understand the state of development in the machine learning applications to biophysics.<br/>I had the following successful learning outcomes from this project:<ol><li>Understood the architecture of U-Net, one of the most successful neural net architecture in biomedical image segmentation (Ronneberger et al., 2015).</li><li>Studied the work of (Schmidt et al., 2022) who used U-Net to predict traction forces from fluorescent images of cells.<ul><li>They create a dataset of fluorescent images of various proteins (zyxin, actin, paxillin, myosin) labels across multiple cells and corresponding measurement of traction forces using traction force microscopy.</li><li>This way, they were able to train a U-Net to predict traction forces (both magnitude and direction) from fluorescent images.</li></ul></li><li>To test the generalizability of the Schimidt et al. model and get hands-on experience of concepts I learned during the course, I applied their model to images unseen by the model. I didn't perform any retraining to update the weights since I don't have access to a novel dataset. I just used the images I found in these publications which use TFM and label zyxin and actin: Kliewe et. al. 2024, Kudrayashov et al., 2022)</li><li>One of the main things I found was that the binary mask threshold when marking the fluorescent parts of an image before feeding it to the model affects the output force prediction. For this project I set the threshold manually, by eyeballing the minimum required threshold to capture maximum information in a given image, but more rigourous analysis on this is required to be certain.</li></ol><p class="lead">Here's an image showing images from Kliewe et. al. 2024, the corresponding binary masks for two different threshold values and the traction forces predicted by the model.</p><figure class="project-figure"><img class="project-figure-image" src="${tractionForceImage.src}" alt="Traction force prediction"/><figcaption>Traction force prediction from fluorescent images of cells using U-Net model. Top row images are from Kliewe et. al. 2024. Middle row images are binary masks created using two different threshold values. Bottom row images are corresponding traction forces predicted by Schmidt et al. U-Net model.</figcaption></figure><p class="lead">While I don't have ground truth traction force data for these images to quantitatively assess the performance of the model, I am happy to get some kind of prediction that is not garbage. This shows that the model has some generalizability to unseen data, at least qualitatively.</p>`,
    tags: ["Cytoskeleton dynamics", "Biophysics", "Machine learning", "Python", "Image analysis"]
  },
  {
    id: "soft-body",
    title: "Soft Body Simulation",
    subtitle: "Introduction to Computational Physics (Spring 2025)",
    shortDescription: "2D mass-spring lattice simulator with collision detection and energy analysis",
    fullDescription: `I developed a 2D soft‑body simulator for the course to get hands‑on experience with building physically motivated models and testing numerical integration strategies. The project focuses on a mass–spring lattice representation of deformable bodies, implementing basic constraints and collision responses, and producing interactive visualisations to inspect deformation and energy behaviour.<ol><li>Derived and implemented the equations of motion for a mass–spring lattice and assembled force contributions from structural, shear, and bending springs.</li><li>Explored time integration schemes and their tradeoffs:<ul><li>Explicit methods (e.g., Verlet / forward Euler) for simplicity and performance.</li><li>Implicit integration (Backward Euler) to improve stability for stiff systems.</li></ul></li><li>Added constraints and collision handling:<ul><li>Fixed anchors and positional constraints to simulate attachments and boundary conditions.</li><li>Simple collision detection and penalty‑based responses against static obstacles and a ground plane.</li></ul></li><li>Studied numerical energy behaviour and damping strategies to avoid numerical blowup while retaining plausible dynamics.</li><li>Built interactive visualisations and example scenes to inspect deformation, stress patterns, and to record simulation runs for analysis.</li></ol><p class="lead">The repository includes the simulator code, example scenes, and a README with instructions to build and run the demos. I used this project to understand how algorithmic choices—integration, constraint handling, and damping—affect stability and visual realism in physics simulations.</p>`,
    tags: ["Mass–spring systems", "Numerical methods", "Energy & stability", "Visualization", "Simulation"]
  }
];

const currentResearch: ProjectCard[] = [
  {
    id: "actin-comet-tail",
    title: "Project 1: Actin comet tail motility simulations",
    subtitle: "Agent-based computational biophysics",
    shortDescription: "Filament-level simulations of actin-propelled bead motility, connecting network architecture to force and motility.",
    fullDescription: `<p class="lead">When certain bacteria like <em>Listeria monocytogenes</em> infect a cell, they hijack the cell's own cytoskeleton: they coat themselves with an actin nucleation-promoting protein and grow a branched actin &ldquo;comet tail&rdquo; that propels them through the cytoplasm. The same physics plays out in any crawling cell, where a branched actin network at the leading edge pushes the cell membrane forward. These networks are a model system for understanding how cells generate and regulate mechanical force.</p><p class="lead">I use three-dimensional Langevin dynamics simulations of these networks to understand the underlying physics of force generation and transmission.</p>`,
    tags: ["Cytoskeleton", "Langevin dynamics", "Actin networks", "Cell motility", "C++", "Python"]
  },
  {
    id: "single-molecule-tracking",
    title: "Project 2: Single-molecule tracking of actin transport in crawling cells",
    subtitle: "Single-molecule speckle microscopy analysis",
    shortDescription: "Quantitative analysis of how actin subunits and regulatory proteins move inside living cells, using single-molecule microscopy data",
    fullDescription: `<p class="lead">A crawling cell continuously burns actin subunits at its leading edge to push the membrane forward. Those subunits must be recycled from sites of disassembly at the rear back to the front. Whether passive diffusion alone is fast enough, or whether the cell employs some form of directed transport, has been a subject of debate for some time.</p><p class="lead">I am currently analyzing trajectory data of single molecules of actin subunits and regulatory proteins inside living cells to quantify their diffusion and drift properties.</p>`,
    tags: ["Single-molecule microscopy", "Diffusion analysis", "Actin dynamics", "Python", "Statistical inference"]
  }
];

const sections: { title: string; note: string; items: ProjectCard[] }[] = [
  { title: "Current Research", note: "ongoing", items: currentResearch },
  { title: "Personal / Hobby", note: "for fun", items: personalProjects },
  { title: "Course Projects", note: "coursework", items: courseProjects },
];
---

<!doctype html>
<html>
  <Header title="Projects | Yashab Yadav" />
  <body class="codex">
    <div class="content">
      <Sidebar selectedItem="projects" />
      <nav class="main">
        <div class="container">
          <!-- Folio -->
          <div class="folio-row">
            <span class="folio">§2 &nbsp;·&nbsp; PROJECTS</span>
            <span class="folio">02</span>
          </div>

          <div class="fold-content">
            <h1 class="heading-red">Projects</h1>
            <p class="lead">
              Here is a collection of projects that I am working on, have worked
              on, or put on a hiatus for one reason or another.
            </p>
            <p class="lead">
              I am a PhD student in Physics at Lehigh University, working with
              <a href="https://www.lehigh.edu/~div206/" target="_blank"
                >Prof. Dimitrios Vavylonis</a
              >. My research is in biophysics, specifically on the mechanics and
              dynamics of <strong>dendritic actin networks</strong>, the branched
              polymer networks that power a variety of cellular processes
              including intracellular transport and cell crawling.
            </p>
          </div>

          {sections.map((section, si) => (
            <section class="project-section">
              <div class="section-rule">
                <span class="prefix">//</span>
                <span class="dash"></span>
                <span class="title">{section.title}</span>
                <span class="dash"></span>
                <span class="note">{section.note}</span>
              </div>
              <div class="bento-grid">
                {section.items.map((project) => (
                  <div class="bento-card" data-project-id={project.id}>
                    <div class="card-header">
                      <h3 class="project-card-title">{project.title}</h3>
                      {project.subtitle && <div class="project-subtitle">{project.subtitle}</div>}
                    </div>
                    <div class="card-content">
                      <p class="project-short-description">{project.shortDescription}</p>
                      <div class="project-full-description" style="display: none;">
                        <Fragment set:html={project.fullDescription} />
                      </div>
                      <div class="chips-container">
                        {project.tags.map((tag) => (
                          <div class="single-chip small-chip">{tag}</div>
                        ))}
                      </div>
                    </div>
                    <div class="expand-indicator">
                      <span class="expand-text">Click to expand ▾</span>
                      <span class="collapse-text" style="display: none;">Click to collapse ▴</span>
                    </div>
                  </div>
                ))}
              </div>
              {si === 0 && (
                <p class="lead research-note">
                  Both research projects are ongoing PhD work. I cannot share
                  unpublished results here, but I am happy to talk about the
                  physics — reach out via the contact links on the home page.
                </p>
              )}
            </section>
          ))}

          <div class="ornament-divider dinkus">
            <span class="glyph">❧</span>
          </div>

          <p class="folio" style="text-align:center;">Last updated April 2026</p>
        </div>
      </nav>
    </div>

    <style>
      .fold-content { max-width: var(--content-max); }
      .research-note {
        font-size: var(--text-small);
        color: var(--text-muted);
        margin-top: 1.25rem;
      }

      /* Bento grid of paper cards */
      .bento-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
        gap: 20px;
        width: 100%;
      }
      .project-section { display: flex; flex-direction: column; }

      .bento-card {
        background-color: var(--surface-card);
        background-image: var(--paper-grain);
        background-size: var(--paper-grain-size);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        padding: 22px;
        box-shadow: var(--shadow-sheet);
        transition: transform var(--dur-base) var(--ease-paper),
                    box-shadow var(--dur-base) var(--ease-paper),
                    border-color var(--dur-base) var(--ease-paper);
        display: flex;
        flex-direction: column;
        cursor: pointer;
        position: relative;
      }
      .bento-card:hover {
        transform: translateY(-2px);
        border-color: var(--rule-strong);
        box-shadow: var(--shadow-lift);
      }
      .bento-card.expanded {
        grid-column: 1 / -1;
        background-color: var(--paper-050);
      }

      .card-header {
        margin-bottom: 1rem;
        border-bottom: 1px solid var(--border-soft);
        padding-bottom: 0.9rem;
      }
      .project-card-title {
        margin: 0;
        font-family: var(--font-display);
        font-size: 1.35rem;
        font-weight: var(--fw-medium);
        color: var(--text-heading);
        line-height: 1.2;
      }
      .project-subtitle {
        color: var(--text-muted);
        font-size: 0.8rem;
        font-family: var(--font-mono);
        margin-top: 0.4rem;
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }

      .card-content { flex: 1; }
      .project-short-description {
        color: var(--text-body);
        font-size: var(--text-small);
        line-height: 1.5;
        margin-bottom: 1rem;
      }

      /* Illuminated initial — Capo Nodi drop cap on the card copy,
         echoing the home-page frontispiece (ink, unframed to stay quiet). */
      .project-short-description::first-letter,
      .project-full-description::first-letter,
      .project-full-description > p:first-child::first-letter {
        font-family: var(--font-dropcap);
        font-size: 3em;
        line-height: 0.72;
        float: left;
        margin: 0.02em 0.09em -0.02em 0;
        color: var(--ink-900);
        font-weight: 400;
      }
      .project-full-description {
        color: var(--text-body);
        font-size: var(--text-small);
        line-height: 1.6;
        margin-bottom: 1.25rem;
      }
      .project-full-description :global(.lead) {
        font-size: var(--text-small);
        line-height: 1.6;
        color: var(--text-body);
        max-width: none;
      }
      .project-full-description :global(ol),
      .project-full-description :global(ul) {
        margin: 0.5rem 0 1rem 1.2rem;
        padding-left: 1rem;
      }
      .project-full-description :global(li) {
        margin-bottom: 0.6rem;
        line-height: 1.5;
      }
      .project-full-description :global(.project-figure) { margin: 1.5rem 0; }
      .project-full-description :global(.project-figure-image) {
        width: 100%;
        border-radius: var(--radius-md);
        border: 1px solid var(--border);
      }
      .project-full-description :global(figcaption) {
        color: var(--text-muted);
        font-family: var(--font-mono);
        font-size: 0.8rem;
        text-align: center;
        margin-top: 0.6rem;
        line-height: 1.4;
      }

      .chips-container {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 1rem;
      }

      .expand-indicator {
        text-align: center;
        margin-top: 1rem;
        padding-top: 0.9rem;
        border-top: 1px dashed var(--rule-strong);
        color: var(--text-rubric);
        font-size: 12px;
        font-family: var(--font-mono);
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      @media screen and (max-width: 991px) {
        .bento-grid { grid-template-columns: 1fr; gap: 18px; }
      }
    </style>

    <script is:inline>
      function initializeProjectCards() {
        const grids = document.querySelectorAll('.bento-grid');

        grids.forEach(grid => {
          grid.addEventListener('click', (event) => {
            const card = event.target.closest('.bento-card');
            if (!card) return;

            const shortDesc = card.querySelector('.project-short-description');
            const fullDesc = card.querySelector('.project-full-description');
            const expandText = card.querySelector('.expand-text');
            const collapseText = card.querySelector('.collapse-text');
            const isExpanded = card.classList.contains('expanded');

            // Close all other expanded cards
            const allCards = grid.querySelectorAll('.bento-card');
            allCards.forEach(otherCard => {
              if (otherCard !== card && otherCard.classList.contains('expanded')) {
                otherCard.classList.remove('expanded');
                const otherShort = otherCard.querySelector('.project-short-description');
                const otherFull = otherCard.querySelector('.project-full-description');
                const otherExpand = otherCard.querySelector('.expand-text');
                const otherCollapse = otherCard.querySelector('.collapse-text');

                otherShort.style.display = 'block';
                otherFull.style.display = 'none';
                otherExpand.style.display = 'inline';
                otherCollapse.style.display = 'none';
              }
            });

            // Toggle current card
            if (isExpanded) {
              card.classList.remove('expanded');
              shortDesc.style.display = 'block';
              fullDesc.style.display = 'none';
              expandText.style.display = 'inline';
              collapseText.style.display = 'none';
            } else {
              card.classList.add('expanded');
              shortDesc.style.display = 'none';
              fullDesc.style.display = 'block';
              expandText.style.display = 'none';
              collapseText.style.display = 'inline';

              // Smooth scroll to the card
              setTimeout(() => {
                card.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
              }, 100);
            }
          });
        });
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initializeProjectCards);
      } else {
        initializeProjectCards();
      }
    </script>
  </body>
</html>
