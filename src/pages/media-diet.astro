---
import Header from "../components/Header.astro";
import Sidebar from "../components/Sidebar.astro";
import favMovies from "../content/media_diet_page/fav_movies.json";
import favTVShows from "../content/media_diet_page/fav_tv_shows.json";
import favGames from "../content/media_diet_page/fav_games.json";
import favBooks from "../content/media_diet_page/fav_books.json";

// Media data - easily updatable

const nowPageData_current = {
  watching: [

    {
      title: "The One (2001)",
      status: "Rewatching",
      reason: "",
      posterUrl: "",
      color: "#8B7355"
    },
    {
      title: "Captive state (2019)",
      status: "Recently rewatched",
      reason: "",
      thoughts: "When I first watched this movie, I didn't really understand it. But on this rewatch, I was blown away by how well it captures the feeling of living under an oppressive regime and the moral complexities of resistance. John Goodman is the GOAT!! This one is a must watch, especially in the current global political climate.",
      posterUrl: "",
      color: "#2D2D2D"
    }
  ],
  playing: [
    {
      title: "Metro 2033 Redux",
      status: "First playthrough",
      reason: "",
      posterUrl: "",
      color: "#4A3E5E"
    },
    {
      title: "Evil West",
      status: "Currently playing",
      thoughts: "Enjoying the combat system so far. Not perfect but the feedback of the gunplay is satisfying.",
      posterUrl: "",
      color: "#2D2D2D"
    }
  ],
  reading: [
    {
      title: "",
      status: "",
      reason: "",
      posterUrl: "",
      color: ""
    }
    ]
};


const nowPageData_favorites = {
  movies: favMovies,
  tvshows: favTVShows,
  games: favGames,
  books: favBooks
};
---

<!doctype html>
<html>
  <Header title="Now | Yashab Yadav" />
  <body>
    <div class="content">
      <Sidebar selectedItem="now" />
      <nav class="main">
        <div class="container">
          <main class="fold-content-container">
            <!-- Hero Section -->
            <div class="fold-content">
              <h1 class="heading-red">What I'm Into At the Moment</h1>
              <p class="lead">
                A peek into my current media diet. Books, films, and games that are capturing my attention right now.
              </p>
            </div>

            <!-- Bento Grid -->
            <div class="bento-grid">
              <!-- Large Card: Currently Watching -->
              <div class="bento-card bento-card-lg">
                <div class="card-header">
                  <h3 class="heading-red">Watching</h3>
                </div>
                <div class="card-content">
                  <div class="status-list">
                    {nowPageData_current.watching.map((item) => (
                      <div class="status-item">
                        <div class="status-title">{item.title}</div>
                        <div class="status-reason">{item.reason}</div>
                        <div class="status-meta">{item.status}</div>
                        <div class="status-thoughts">{item.thoughts}</div>
                      </div>
                    ))}
                  </div>
                </div>
              </div>

              <!-- Large Card: Currently Playing -->
              <div class="bento-card bento-card-lg">
                <div class="card-header">
                  <h3 class="heading-red">Playing</h3>
                </div>
                <div class="card-content">
                  <div class="status-list">
                    {nowPageData_current.playing.map((item) => (
                      <div class="status-item">
                        <div class="status-title">{item.title}</div>
                        <div class="status-reason">{item.reason}</div>
                        <div class="status-meta">{item.status}</div>
                        <div class="status-thoughts">{item.thoughts}</div>
                      </div>
                    ))}
                  </div>
                </div>
              </div>

              <!-- Large Card: Currently Reading -->
              <!-- div class="bento-card bento-card-lg">
                <div class="card-header">
                  <h3 class="heading-red">Reading</h3>
                </div>
                <div class="card-content">
                  <div class="status-list">
                    {nowPageData_current.reading.map((item) => (
                      <div class="status-item">
                        <div class="status-title">{item.title}</div>
                        <div class="status-reason">{item.reason}</div>
                        <div class="status-meta">{item.status}</div>
                      </div>
                    ))}
                  </div>
                </div>
              </div-->
            </div>

            <!-- Poster Gallery Section -->
            <div class="poster-section">
              <h2 class="heading-red" style="margin-top: 3rem; margin-bottom: 1.5rem;">Favourites of All Time</h2>
              
              <!-- Movies -->
              <div class="gallery-subsection">
                <h3 class="gallery-subheading">Movies</h3>
                <div class="poster-grid">
                  {nowPageData_favorites.movies.map((item) => (
                    <div class="poster-card">
                      <div class="poster-image-container" style={`--accent-color: ${item.color || '#353535'}`}>
                        <img 
                          src={item.posterUrl} 
                          alt={item.title}
                          class="poster-image"
                        />
                        <div class="poster-overlay"></div>
                      </div>
                      <div class="poster-info">
                        <div class="poster-title">{item.title}</div>
                        <div class="poster-subtitle">{item.reason}</div>
                      </div>
                    </div>
                  ))}
                </div>
              </div>

              <!-- TV Shows -->
              <div class="gallery-subsection">
                <h3 class="gallery-subheading">TV Shows</h3>
                <div class="poster-grid">
                  {nowPageData_favorites.tvshows.map((item) => (
                    <div class="poster-card">
                      <div class="poster-image-container" style={`--accent-color: ${item.color || '#353535'}`}>
                        <img 
                          src={item.posterUrl} 
                          alt={item.title}
                          class="poster-image"
                        />
                        <div class="poster-overlay"></div>
                      </div>
                      <div class="poster-info">
                        <div class="poster-title">{item.title}</div>
                        <div class="poster-subtitle">{item.reason}</div>
                      </div>
                    </div>
                  ))}
                </div>
              </div>

              <!-- Video Games -->
              <div class="gallery-subsection">
                <h3 class="gallery-subheading">Video Games</h3>
                <div class="poster-grid">
                  {nowPageData_favorites.games.map((item) => (
                    <div class="poster-card">
                      <div class="poster-image-container" style={`--accent-color: ${item.color || '#353535'}`}>
                        <img 
                          src={item.posterUrl} 
                          alt={item.title}
                          class="poster-image"
                        />
                        <div class="poster-overlay"></div>
                      </div>
                      <div class="poster-info">
                        <div class="poster-title">{item.title}</div>
                        <div class="poster-subtitle">{item.reason}</div>
                      </div>
                    </div>
                  ))}
                </div>
              </div>

              <!-- Books -->
              <div class="gallery-subsection">
                <h3 class="gallery-subheading">Books</h3>
                <div class="poster-grid">
                  {nowPageData_favorites.books.map((item) => (
                    <div class="poster-card">
                      <div class="poster-image-container" style={`--accent-color: ${item.color || '#353535'}`}>
                        <img 
                          src={item.posterUrl} 
                          alt={item.title}
                          class="poster-image"
                        />
                        <div class="poster-overlay"></div>
                      </div>
                      <div class="poster-info">
                        <div class="poster-title">{item.title}</div>
                        <div class="poster-subtitle">{item.reason}</div>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            </div>

            <!-- Footer Note -->
            <div class="fold-content" style="margin-top: 3rem; border-top: 1px solid #353535; padding-top: 2rem;">
              <p class="lead" style="font-size: 14px; color: #a8a8a8;">
                Last updated: February 2025. This page is regularly updated as my media diet evolves.
              </p>
            </div>
          </main>
        </div>
      </nav>
    </div>

    <style>
      /* Bento Grid Container */
      .bento-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 24px;
        margin: 2rem 0;
        width: 100%;
      }

      /* Bento Cards */
      .bento-card {
        background-color: rgba(53, 53, 53, 0.12);
        border: 1px solid #353535;
        border-radius: 12px;
        padding: 24px;
        backdrop-filter: blur(4px);
        transition: all 200ms ease;
        display: flex;
        flex-direction: column;
      }

      .bento-card:hover {
        border-color: #803329;
        background-color: rgba(53, 53, 53, 0.18);
        box-shadow: 0 8px 24px rgba(128, 51, 41, 0.12);
      }

      .bento-card-lg {
        min-height: 280px;
      }

      /* Card Header */
      .card-header {
        margin-bottom: 1.5rem;
        border-bottom: 1px solid #353535;
        padding-bottom: 1rem;
      }

      .card-header h3 {
        margin: 0;
        font-size: 1.4rem;
        color: #803329;
      }

      /* Card Content */
      .card-content {
        flex: 1;
        overflow-y: auto;
      }

      /* Status List */
      .status-list {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
      }

      .status-item {
        padding: 0;
      }

      .status-title {
        color: #D4D4CA;
        font-size: 17px;
        font-weight: 500;
        margin-bottom: 0.25rem;
        line-height: 1.4;
      }

      .status-meta {
        color: #a8a8a8;
        font-size: 13px;
        font-family: IBM Plex Mono, sans-serif;
        margin-bottom: 0.5rem;
        letter-spacing: 0.5px;
      }
      
      .status-thoughts {
        color: #c0c0c0;
        font-size: 13px;
        line-height: 1.5;
      }

      .status-reason {
        color: #808080;
        font-size: 13px;
        line-height: 1.4;
        font-style: italic;
      }

      /* Poster Section */
      .poster-section {
        margin-top: 2rem;
      }

      .gallery-subsection {
        margin-bottom: 3rem;
      }

      .gallery-subheading {
        color: #803329;
        font-size: 1.1rem;
        margin-bottom: 1rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        font-family: IBM Plex Mono, sans-serif;
        font-weight: 500;
      }

      /* Poster Grid */
      .poster-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
        gap: 20px;
      }

      /* Poster Card */
      .poster-card {
        display: flex;
        flex-direction: column;
        gap: 10px;
        cursor: pointer;
      }

      .poster-image-container {
        position: relative;
        width: 100%;
        aspect-ratio: 3 / 4;
        border-radius: 8px;
        overflow: hidden;
        background-color: #1c1c1c;
        border: 1px solid #353535;
        transition: all 250ms ease;
      }

      .poster-image-container:hover {
        border-color: #803329;
        box-shadow: 
          0 0 20px rgba(128, 51, 41, 0.3),
          inset 0 0 0 1px rgba(128, 51, 41, 0.4);
        filter: brightness(1.15);
      }

      .poster-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 250ms ease;
      }

      .poster-image-container:hover .poster-image {
        transform: scale(1.05);
      }

      .poster-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, rgba(128, 51, 41, 0) 0%, rgba(128, 51, 41, 0.15) 100%);
        opacity: 0;
        transition: opacity 250ms ease;
      }

      .poster-image-container:hover .poster-overlay {
        opacity: 1;
      }

      /* Poster Info */
      .poster-info {
        display: flex;
        flex-direction: column;
        gap: 4px;
      }

      .poster-title {
        color: #D4D4CA;
        font-size: 13px;
        font-weight: 500;
        line-height: 1.3;
      }

      .poster-subtitle {
        color: #a8a8a8;
        font-size: 12px;
        line-height: 1.3;
      }

      /* Responsive Design */
      @media screen and (max-width: 991px) {
        .bento-grid {
          grid-template-columns: 1fr;
          gap: 20px;
        }

        .bento-card {
          min-height: 200px;
        }

        .poster-grid {
          grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
          gap: 16px;
        }
      }

      @media screen and (max-width: 767px) {
        .bento-grid {
          gap: 16px;
        }

        .bento-card {
          padding: 18px;
          border-radius: 8px;
        }

        .card-header {
          margin-bottom: 1rem;
          padding-bottom: 0.8rem;
        }

        .card-header h3 {
          font-size: 1.2rem;
        }

        .status-item {
          padding: 0.75rem 0;
        }

        .status-title {
          font-size: 14px;
        }

        .status-meta {
          font-size: 12px;
        }

        .poster-grid {
          grid-template-columns: repeat(3, 1fr);
          gap: 12px;
        }

        .gallery-subheading {
          font-size: 0.95rem;
          margin-bottom: 0.8rem;
        }

        .poster-info {
          gap: 3px;
        }

        .poster-title {
          font-size: 12px;
        }

        .poster-subtitle {
          font-size: 11px;
        }
      }

      @media screen and (max-width: 480px) {
        .poster-grid {
          grid-template-columns: repeat(2, 1fr);
          gap: 10px;
        }

        .bento-grid {
          gap: 12px;
        }
      }
    </style>
  </body>
</html>
