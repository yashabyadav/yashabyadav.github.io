---
import Header from "../components/Header.astro";
import Sidebar from "../components/Sidebar.astro";
import favMovies from "../content/media_diet_page/fav_movies.json";
import favTVShows from "../content/media_diet_page/fav_tv_shows.json";
import favVideoGames from "../content/media_diet_page/fav_video_games.json";
import favBooks from "../content/media_diet_page/fav_books.json";
import currentMedia from "../content/media_diet_page/current.json";

const nowPageData_current = currentMedia;

const nowPageData_favorites = {
  movies: favMovies,
  tvshows: favTVShows,
  games: favVideoGames,
  books: favBooks
};

const galleries: { title: string; items: { title: string; posterUrl?: string; color?: string }[] }[] = [
  { title: "Movies", items: nowPageData_favorites.movies },
  { title: "TV Shows", items: nowPageData_favorites.tvshows },
  { title: "Video Games", items: nowPageData_favorites.games },
];
---

<!doctype html>
<html>
  <Header title="Media diet | Yashab Yadav" />
  <body class="codex">
    <div class="content">
      <Sidebar selectedItem="media-diet" />
      <nav class="main">
        <div class="container">
          <!-- Folio -->
          <div class="folio-row">
            <span class="folio">§4 &nbsp;·&nbsp; MEDIA DIET</span>
            <span class="folio">04</span>
          </div>

          <div class="fold-content">
            <h1 class="heading-red">The media that I am currently into</h1>
            <p class="lead">
              A peek into my current media diet. Films, TV shows, and games that
              are capturing my attention right now.
            </p>
          </div>

          <!-- Currently -->
          <section>
            <div class="section-rule">
              <span class="prefix">//</span>
              <span class="dash"></span>
              <span class="title">Currently</span>
              <span class="dash"></span>
              <span class="note">now</span>
            </div>
            <div class="bento-grid">
              <div class="bento-card bento-card-lg">
                <div class="card-header">
                  <div class="card-kicker">Watching</div>
                </div>
                <div class="card-content">
                  <div class="status-list">
                    {nowPageData_current.watching.map((item) => (
                      <div class="status-item">
                        <div class="status-title">{item.title}</div>
                        <div class="status-reason">{item.reason}</div>
                        <div class="status-meta">{item.status}</div>
                        <div class="status-thoughts" set:html={item.thoughts} />
                      </div>
                    ))}
                  </div>
                </div>
              </div>

              <div class="bento-card bento-card-lg">
                <div class="card-header">
                  <div class="card-kicker">Playing</div>
                </div>
                <div class="card-content">
                  <div class="status-list">
                    {nowPageData_current.playing.map((item) => (
                      <div class="status-item">
                        <div class="status-title">{item.title}</div>
                        <div class="status-reason">{item.reason}</div>
                        <div class="status-meta">{item.status}</div>
                        <div class="status-thoughts" set:html={item.thoughts} />
                      </div>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          </section>

          <div class="ornament-divider">
            <span class="rule"></span>
            <span class="glyph">•◆•</span>
            <span class="rule"></span>
          </div>

          <!-- Favourites -->
          <section class="poster-section">
            <div class="section-rule">
              <span class="prefix">//</span>
              <span class="dash"></span>
              <span class="title">Favourites of All Time</span>
              <span class="dash"></span>
              <span class="note">no order</span>
            </div>
            <p class="lead" style="margin-bottom: 2rem;">
              These are some of my favorites of all time, in no particular order.
            </p>

            {galleries.map((gallery) => (
              <div class="gallery-subsection">
                <h3 class="gallery-subheading">{gallery.title}</h3>
                <div class="poster-grid">
                  {gallery.items.map((item) => (
                    <div class="poster-card">
                      <div class="poster-image-container">
                        <img
                          src={item.posterUrl || '/assets/poster-placeholder.svg'}
                          alt={item.title}
                          class="poster-image"
                          onerror="this.onerror=null;this.src='/assets/poster-placeholder.svg'"
                        />
                        <div class="poster-overlay"></div>
                      </div>
                      <div class="poster-info">
                        <div class="poster-title">{item.title}</div>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            ))}
          </section>

          <div class="ornament-divider dinkus">
            <span class="glyph">❧</span>
          </div>

          <p class="folio" style="text-align:center;">Last updated June 2026</p>
        </div>
      </nav>
    </div>

    <style>
      .fold-content { max-width: var(--content-max); }

      /* Bento grid */
      .bento-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 20px;
        width: 100%;
      }
      .bento-card {
        background-color: var(--surface-card);
        background-image: var(--paper-grain);
        background-size: var(--paper-grain-size);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        padding: 22px;
        box-shadow: var(--shadow-sheet);
        transition: transform var(--dur-base) var(--ease-paper),
                    box-shadow var(--dur-base) var(--ease-paper);
        display: flex;
        flex-direction: column;
      }
      .bento-card:hover { transform: translateY(-2px); box-shadow: var(--shadow-lift); }
      .bento-card-lg { min-height: 240px; }

      .card-header {
        margin-bottom: 1.25rem;
        border-bottom: 1px solid var(--border-soft);
        padding-bottom: 0.8rem;
      }
      .card-kicker {
        font-family: var(--font-mono);
        font-size: 11px;
        color: var(--text-rubric);
        text-transform: uppercase;
        letter-spacing: 0.12em;
      }

      .card-content { flex: 1; overflow-y: auto; }
      .status-list { display: flex; flex-direction: column; gap: 1.4rem; }
      .status-title {
        color: var(--text-strong);
        font-family: var(--font-display);
        font-size: 19px;
        margin-bottom: 0.25rem;
        line-height: 1.3;
      }
      /* Illuminated initial on each entry title (Capo Nodi, ink) */
      .status-title::first-letter {
        font-family: var(--font-dropcap);
        font-size: 2.4em;
        line-height: 0.7;
        float: left;
        margin: 0.05em 0.1em 0 0;
        color: var(--ink-900);
        font-weight: 400;
      }
      .status-meta {
        color: var(--text-faint);
        font-size: 12px;
        font-family: var(--font-mono);
        margin-bottom: 0.5rem;
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }
      .status-thoughts { color: var(--text-body); font-size: 14px; line-height: 1.5; }
      .status-reason { color: var(--text-muted); font-size: 14px; line-height: 1.4; font-style: italic; }

      /* Poster galleries */
      .poster-section { display: flex; flex-direction: column; }
      .gallery-subsection { margin-bottom: 2.5rem; }
      .gallery-subheading {
        color: var(--text-muted);
        font-family: var(--font-mono);
        font-size: 0.95rem;
        font-weight: var(--fw-regular);
        margin-bottom: 1rem;
        text-transform: uppercase;
        letter-spacing: 0.14em;
      }
      .poster-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
        gap: 18px;
      }
      .poster-card { display: flex; flex-direction: column; gap: 10px; cursor: pointer; }
      .poster-image-container {
        position: relative;
        width: 100%;
        aspect-ratio: 3 / 4;
        border-radius: var(--radius-md);
        overflow: hidden;
        background-color: var(--surface-sunk);
        border: 1px solid var(--border);
        box-shadow: var(--shadow-sheet);
        transition: transform var(--dur-base) var(--ease-paper),
                    box-shadow var(--dur-base) var(--ease-paper),
                    border-color var(--dur-base) var(--ease-paper);
        /* printed-plate treatment: cool & slightly desaturated */
        filter: grayscale(0.25) contrast(1.02);
      }
      .poster-image-container:hover {
        transform: translateY(-3px);
        border-color: var(--rule-strong);
        box-shadow: var(--shadow-lift);
        filter: grayscale(0) contrast(1.04);
      }
      .poster-image { width: 100%; height: 100%; object-fit: cover; transition: transform var(--dur-base) var(--ease-paper); }
      .poster-image-container:hover .poster-image { transform: scale(1.04); }
      .poster-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, transparent 0%, var(--wash-warm) 100%);
        opacity: 0;
        transition: opacity var(--dur-base) var(--ease-paper);
      }
      .poster-image-container:hover .poster-overlay { opacity: 1; }
      .poster-info { display: flex; flex-direction: column; gap: 4px; }
      .poster-title { color: var(--text-body); font-size: 13px; line-height: 1.3; }

      @media screen and (max-width: 991px) {
        .bento-grid { grid-template-columns: 1fr; gap: 18px; }
        .poster-grid { grid-template-columns: repeat(auto-fill, minmax(120px, 1fr)); gap: 16px; }
      }
      @media screen and (max-width: 767px) {
        .poster-grid { grid-template-columns: repeat(3, 1fr); gap: 12px; }
      }
      @media screen and (max-width: 480px) {
        .poster-grid { grid-template-columns: repeat(2, 1fr); gap: 10px; }
      }
    </style>
  </body>
</html>
